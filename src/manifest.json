{
  "manifest_version": 3,
  "name": "WhatsApp+",
  "version": "0.0.1",
  "description": "A simple lightweight privacy extension for Whatsapp Web on Google Chrome and Microsoft Edge.",
  "permissions": ["storage", "tabs"],
  "icons": {
    "512": "assets/whatsapp.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/whatsapp.png"
  },
  "background": {
    "service_worker": "scripts/background.js",
    "scripts": ["background.js"]
  },
  "commands": {
    "toggle-all-privacy": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Panic button to blur all"
    }
  },
    "browser_specific_settings": {
    "gecko": {
      "id": "@whatsapp-plus",
      "strict_min_version": "130.0.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["scripts/content.js"]
    }
  ]
}