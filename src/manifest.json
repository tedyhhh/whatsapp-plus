{
  "manifest_version": 3,
  "name": "WhatsApp+",
  "version": "0.0.1",
  "description": "Enhance your privacy with a simple message, media, and name blur",
  "permissions": ["storage", "tabs"],
  "icons": {
    "512": "assets/whatsapp.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/whatsapp.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "commands": {
    "toggle-all-privacy": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Panic button to blur all"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["scripts/content.js"]
    }
  ]
}